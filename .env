# LLM provider: ollama | groq | hf | auto (try all in order)
LLM_PROVIDER=auto

# Ollama (local) — used when running locally with Ollama installed
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# HuggingFace — free tier, needs HF_TOKEN (auto-discovered from ~/.cache/huggingface/token)
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
